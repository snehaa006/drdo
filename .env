# ─────────────────────────────────────────────────────────────────────────────
#  DRDO GIS — on-site configuration.  EDIT THIS FILE ONLY (no code changes).
#  Applies to both docker-compose.yml and docker-compose.offline.yml.
# ─────────────────────────────────────────────────────────────────────────────

# ── Terrain data locations on THIS machine ──────────────────────────────────
# Point these at DRDO's terrain data. They are mounted read-only into the app.
# Windows example:  DTED_HOST_DIR=C:/drdo/terrain/dted
# Linux example:    DTED_HOST_DIR=/mnt/drdo/terrain/dted
DTED_HOST_DIR=./data/terrain/dted
GEOTIFF_HOST_DIR=./data/terrain/geotiff

# Which GeoTIFF (a file name inside GEOTIFF_HOST_DIR) to show as the map base
# layer. Change this to DRDO's own base map file name if they provide one.
# Leave blank to just use whichever GeoTIFF is found first.
DEFAULT_BASE_MAP=india_basemap.tif

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=drdo_gis
POSTGRES_USER=drdo_user
POSTGRES_PASSWORD=drdo_secret

# ── Host ports (change if these are already in use on the DRDO machine) ──────
FRONTEND_PORT=4200
BACKEND_PORT=8080
POSTGRES_PORT=5432
